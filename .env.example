APP_ENV=development
APP_URL=http://localhost:3000

# Base de datos (SQLite local → cambiar a PostgreSQL en producción)
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET="sherman-finance-v2-jwt-secret-min-32-chars-change-in-prod"
ENCRYPTION_KEY="sherman-encrypt-key-exactly-32b!"

# ─── SUNAT ─────────────────────────────────────────────
# mock = datos simulados (para desarrollo)
# direct = API real SUNAT (requiere credenciales de SOL)
SUNAT_PROVIDER="mock"

# Obtener en: SOL → Empresas → Credenciales API SUNAT
# Tipo: clientesextranet (Consulta Integrada CPE)
SUNAT_CLIENT_ID=""
SUNAT_CLIENT_SECRET=""

# Para SIRE (se usa con clientessol en el token)
# El usuario SOL se guarda cifrado por empresa en la BD
# No poner aquí — usar el módulo Empresas para configurar por empresa

# URLs base (no cambiar en producción)
SUNAT_API_BASE_URL="https://api-seguridad.sunat.gob.pe/v1"
SUNAT_VALIDATE_URL="https://api.sunat.gob.pe/v1"
SUNAT_SIRE_URL="https://api-sire.sunat.gob.pe/v1"

# ─── CONCAR SQL ────────────────────────────────────────
# mock = sin conexión real
# sqlserver = SQL Server real (requiere mssql package)
CONCAR_PROVIDER="mock"
CONCAR_SQL_SERVER=""
CONCAR_SQL_DATABASE=""
CONCAR_SQL_USER=""
CONCAR_SQL_PASSWORD=""
CONCAR_SQL_ENCRYPT="true"
CONCAR_SQL_TRUST_CERT="false"

# ─── IA ────────────────────────────────────────────────
# mock = reglas por palabras clave PCGE
# openai = Claude/OpenAI real
AI_PROVIDER="mock"
OPENAI_API_KEY=""

# ─── ALMACENAMIENTO ────────────────────────────────────
STORAGE_PATH="./storage"
